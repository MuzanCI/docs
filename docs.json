{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "MuzanCI",
  "colors": {
    "primary": "#ef4444",
    "dark": "#b91c1c",
    "light": "#fca5a5"
  },
  "favicon": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png"
  },
  "banner": {
    "content": "Muzan CI is free for public repositories. [Learn more about limits](/limits)"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "pages": [
          "index",
          "install-on-github",
          {
            "group": "How it works",
            "pages": [
              "how-it-works/overview",
              "how-it-works/pipelines",
              "how-it-works/images",
              "how-it-works/rules",
              "how-it-works/jobs",
              "how-it-works/envvars-and-secrets",
              "how-it-works/artifacts",
              "how-it-works/cache",
              "how-it-works/ssh-access",
              "how-it-works/managed-runners",
              "how-it-works/self-hosted-runners"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/hello-world",
              "examples/rules",
              "examples/jobs",
              "examples/envvars-and-secrets",
              "examples/artifacts",
              "examples/cache",
              "examples/managed-runners",
              "examples/self-hosted-runners"
            ]
          }
        ]
      },
      {
        "tab": "Blog",
        "pages": [
          "blog"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Help",
      "href": "https://github.com/MuzanCI/feedback/issues/new"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/MuzanCI/feedback/issues/new",
      "discord": "https://discord.gg/6VY5xRXV2"
    },
    "links": [
      {
        "header": "Links",
        "items": [
          {
            "label": "Terms of Use",
            "href": "/terms-of-use"
          },
          {
            "label": "Privacy Policy",
            "href": "/privacy-policy"
          }
        ]
      }
    ]
  },
  "description": "FreeBSD and Linux CI runners",
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "interaction": {
    "drilldown": true
  },
  "errors": {
    "404": {
      "redirect": false,
      "description": "The URL that you were looking for does not exist. Please check your URL or [go back to home](https://muzanci.com/)"
    }
  },
  "icons": {
    "library": "lucide"
  }
}
